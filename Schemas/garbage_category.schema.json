{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kadoma garbage category split data",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "shortName",
      "symbolName",
      "colorHex",
      "disposalRule",
      "notes",
      "defaultPreviousNightNotification",
      "defaultMorningNotification"
    ],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "name": { "type": "string", "minLength": 1 },
      "shortName": { "type": "string", "minLength": 1 },
      "symbolName": { "type": "string", "minLength": 1 },
      "colorHex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
      "disposalRule": { "type": "string", "minLength": 1 },
      "notes": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "defaultPreviousNightNotification": { "type": "boolean" },
      "defaultMorningNotification": { "type": "boolean" }
    }
  }
}
