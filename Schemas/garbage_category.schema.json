{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kadoma garbage category split data",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "shortName",
      "symbolName",
      "colorHex",
      "disposalRule",
      "notes",
      "defaultPreviousNightNotification",
      "defaultMorningNotification",
      "displayName",
      "description",
      "iconName",
      "colorToken",
      "disposalSummary",
      "disposalSteps",
      "warnings",
      "examples",
      "collectionMethod",
      "requiresReservation",
      "requiresOfficialCheck",
      "sourceUrl",
      "sourceTitle",
      "confidenceStatus",
      "updatedAt"
    ],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "name": { "type": "string", "minLength": 1 },
      "shortName": { "type": "string", "minLength": 1 },
      "symbolName": { "type": "string", "minLength": 1 },
      "colorHex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
      "disposalRule": { "type": "string", "minLength": 1 },
      "notes": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "defaultPreviousNightNotification": { "type": "boolean" },
      "defaultMorningNotification": { "type": "boolean" },
      "displayName": { "type": "string", "minLength": 1 },
      "description": { "type": "string", "minLength": 1 },
      "iconName": { "type": "string", "minLength": 1 },
      "colorToken": { "type": "string", "minLength": 1 },
      "disposalSummary": { "type": "string", "minLength": 1 },
      "disposalSteps": {
        "type": "array",
        "minItems": 3,
        "items": { "type": "string", "minLength": 1 }
      },
      "warnings": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "examples": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      },
      "collectionMethod": { "type": "string", "minLength": 1 },
      "requiresReservation": { "type": "boolean" },
      "requiresOfficialCheck": { "type": "boolean" },
      "sourceUrl": { "type": "string", "minLength": 1 },
      "sourceTitle": { "type": "string", "minLength": 1 },
      "confidenceStatus": {
        "type": "string",
        "enum": ["confirmed", "needs_review", "estimated"]
      },
      "updatedAt": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  }
}
