{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kadoma production master",
  "type": "object",
  "required": [
    "municipalityCode",
    "municipalityName",
    "targetAddressPreset",
    "defaultAreaId",
    "fiscalYear",
    "version",
    "sourceUpdatedAt",
    "generatedAt",
    "sourcePages",
    "areas",
    "categories",
    "itemDictionary",
    "notices"
  ],
  "properties": {
    "municipalityCode": { "type": "string", "pattern": "^\\d{5}$" },
    "municipalityName": { "type": "string", "minLength": 1 },
    "targetAddressPreset": { "type": "string", "minLength": 1 },
    "defaultAreaId": { "type": "string", "pattern": "^[A-Z]$" },
    "fiscalYear": { "type": "integer" },
    "version": { "type": "string", "minLength": 1 },
    "sourceUpdatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "sourcePages": { "type": "array", "minItems": 1 },
    "areas": { "type": "array", "minItems": 1 },
    "categories": { "type": "array", "minItems": 1 },
    "itemDictionary": { "type": "array", "minItems": 1 },
    "notices": { "type": "array" },
    "exceptionRules": { "type": "array" }
  }
}
