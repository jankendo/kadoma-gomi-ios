{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kadoma garbage item split data",
  "type": "array",
  "minItems": 200,
  "items": {
    "type": "object",
    "required": [
      "id",
      "names",
      "displayName",
      "kana",
      "aliases",
      "categoryId",
      "keywords",
      "notes",
      "disposalGuide",
      "warnings",
      "isOversizedCandidate",
      "isHazardous",
      "requiresOfficialCheck",
      "source",
      "sourceUrl",
      "confidence",
      "confidenceStatus",
      "updatedAt",
      "subcategoryName",
      "disposalSteps",
      "preparationBeforeDisposal",
      "sizeRule",
      "bundleRule",
      "washingRequired",
      "removeCapsLabels",
      "drainContents",
      "separateMaterials",
      "requiresReservation",
      "sourceTitle"
    ],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "names": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      },
      "displayName": { "type": "string", "minLength": 1 },
      "kana": { "type": "string", "minLength": 1 },
      "aliases": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "categoryId": { "type": "string", "minLength": 1 },
      "keywords": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "notes": { "type": "string", "minLength": 1 },
      "disposalGuide": { "type": "string", "minLength": 1 },
      "warnings": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "isOversizedCandidate": { "type": "boolean" },
      "isHazardous": { "type": "boolean" },
      "requiresOfficialCheck": { "type": "boolean" },
      "source": { "type": "string", "minLength": 1 },
      "sourceUrl": { "type": "string", "minLength": 1 },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "confidenceStatus": {
        "type": "string",
        "enum": ["confirmed", "needs_review", "estimated"]
      },
      "updatedAt": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "subcategoryName": { "type": "string", "minLength": 1 },
      "disposalSteps": {
        "type": "array",
        "minItems": 2,
        "items": { "type": "string", "minLength": 1 }
      },
      "preparationBeforeDisposal": { "type": "string", "minLength": 1 },
      "sizeRule": { "type": "string" },
      "bundleRule": { "type": "string" },
      "washingRequired": { "type": "boolean" },
      "removeCapsLabels": { "type": "boolean" },
      "drainContents": { "type": "boolean" },
      "separateMaterials": { "type": "boolean" },
      "requiresReservation": { "type": "boolean" },
      "sourceTitle": { "type": "string", "minLength": 1 }
    }
  }
}
