{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kadoma special rules split data",
  "type": "object",
  "required": [
    "notices",
    "exceptions",
    "exceptionRules"
  ],
  "properties": {
    "notices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "body",
          "monthHints",
          "sourceUrl",
          "confirmedAt",
          "confidence"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "monthHints": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1, "maximum": 12 }
          },
          "sourceUrl": { "type": "string", "minLength": 1 },
          "confirmedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "confidence": {
            "type": "string",
            "enum": ["confirmed", "needs_review", "estimated"]
          }
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "areaId",
          "categoryId",
          "action",
          "reason",
          "sourceUrl",
          "confirmedAt",
          "confidence"
        ],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "areaId": { "type": "string", "pattern": "^[A-F]$" },
          "categoryId": { "type": "string", "minLength": 1 },
          "action": {
            "type": "string",
            "enum": ["add", "cancel", "note"]
          },
          "reason": { "type": "string", "minLength": 1 },
          "sourceUrl": { "type": "string", "minLength": 1 },
          "confirmedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "confidence": {
            "type": "string",
            "enum": ["confirmed", "needs_review", "estimated"]
          }
        }
      }
    },
    "exceptionRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "areaIds",
          "dateFrom",
          "dateTo",
          "type",
          "affectedCategories",
          "title",
          "description",
          "sourceUrl",
          "confirmedAt",
          "confidence"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "areaIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[A-F]$" }
          },
          "dateFrom": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "dateTo": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "type": { "type": "string", "minLength": 1 },
          "affectedCategories": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "sourceUrl": { "type": "string", "minLength": 1 },
          "confirmedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "confidence": {
            "type": "string",
            "enum": ["confirmed", "needs_review", "estimated"]
          }
        }
      }
    }
  }
}
