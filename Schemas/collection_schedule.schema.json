{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kadoma collection schedule split data",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "areaId",
      "id",
      "categoryId",
      "recurrenceType",
      "weekdays",
      "weekOfMonth",
      "specificDates",
      "validFrom",
      "validTo",
      "sourceStatus"
    ],
    "properties": {
      "areaId": { "type": "string", "pattern": "^[A-Z]$" },
      "id": { "type": "string", "minLength": 1 },
      "categoryId": { "type": "string", "minLength": 1 },
      "recurrenceType": {
        "type": "string",
        "enum": ["weekly", "monthlyNthWeekday", "specificDates"]
      },
      "weekdays": {
        "type": ["array", "null"],
        "items": { "type": "integer", "minimum": 1, "maximum": 7 }
      },
      "weekOfMonth": {
        "type": ["array", "null"],
        "items": { "type": "integer", "minimum": 1, "maximum": 5 }
      },
      "specificDates": {
        "type": ["array", "null"],
        "items": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      },
      "validFrom": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "validTo": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "sourceStatus": {
        "type": "string",
        "enum": ["official-confirmed", "manual-review", "unconfirmed"]
      }
    }
  }
}
