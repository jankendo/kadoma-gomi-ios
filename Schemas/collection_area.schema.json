{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kadoma collection area split data",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "name", "sourceStatus", "towns"],
    "properties": {
      "id": { "type": "string", "pattern": "^[A-Z]$" },
      "name": { "type": "string", "minLength": 1 },
      "sourceStatus": {
        "type": "string",
        "enum": ["official-confirmed", "manual-review", "unconfirmed"]
      },
      "towns": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["townName", "areaId", "blockRange"],
          "properties": {
            "townName": { "type": "string", "minLength": 1 },
            "areaId": { "type": "string", "pattern": "^[A-Z]$" },
            "blockRange": { "type": ["string", "null"] }
          }
        }
      }
    }
  }
}
